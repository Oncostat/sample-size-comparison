          <Row index="3">
            <Parameter id="PiOne" name="PiOne" title="Group 1 Proportions, π₁​" type="Decimal" helpUri="Help/PTT/PTT12/PiOne.html" readonly="false" format="F3">
              <Rules>
                <Rule name="Validate group 1 proportions, π₁" type="validation" message="The value entered for group 1 proportions, π₁, is outside the acceptable limits.">PiOne &gt; 0 and PiOne &lt; 1</Rule>
                <Rule name="Update Group 2 proportions" type="action">if((PiOne != null) and (OddsRatio != null) and (PiTwo == null)) { PiTwo = (OddsRatio*PiOne)/((1.0-PiOne)+(OddsRatio*PiOne)) }</Rule>
                <Rule name="Update odds ratio" type="action">if((PiOne != null) and (PiTwo != null)) { OddsRatio = (PiTwo*(1.0-PiOne))/(PiOne*(1.0-PiTwo)) }</Rule>
              </Rules>
            </Parameter>
