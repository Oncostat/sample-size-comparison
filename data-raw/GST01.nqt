      <MultipleFactors id="MultipleFactor1" caption="Specify Multiple Factors" active="True">
        <MultipleFactorRow>
          <Parameter id="Alpha" name="Alpha" title="Test Significance Level, α​" type="Decimal" helpUri="Help/PTT/PTT12/Alpha.html" readonly="false" format="F10">
            <Rules>
              <Rule name="Validate test significance level, α" type="validation" message="The significance level, α, is outside the acceptable limits.">Alpha &gt;= 0.001 and Alpha &lt;= 0.20</Rule>
            </Rules>
          </Parameter>
          <V0>0.001</V0>
          <V1>0.025</V1>
          <V2>0.05</V2>
          <V3>0.1</V3>
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="HypothesisType" name="HypothesisType" title="1 or 2 Sided Test?​" type="HypothesisType" defaultValue="1" helpUri="Help/PTT/PTT12/HypothesisType.html" readonly="false">
            <Rules />
          </Parameter>
          <V0>One</V0>
          <V1>One</V1>
          <V2>One</V2>
          <V3>One</V3>
          <V4>One</V4>
          <V5>One</V5>
          <V6>One</V6>
          <V7>One</V7>
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="PiOne" name="PiOne" title="Group 1 Proportions, π₁​" type="Decimal" helpUri="Help/PTT/PTT12/PiOne.html" readonly="false" format="F3">
            <Rules>
              <Rule name="Validate group 1 proportions, π₁" type="validation" message="The value entered for group 1 proportions, π₁, is outside the acceptable limits.">PiOne &gt; 0 and PiOne &lt; 1</Rule>
              <Rule name="Update Group 2 proportions" type="action">if((PiOne != null) and (OddsRatio != null) and (PiTwo == null)) { PiTwo = (OddsRatio*PiOne)/((1.0-PiOne)+(OddsRatio*PiOne)) }</Rule>
              <Rule name="Update odds ratio" type="action">if((PiOne != null) and (PiTwo != null)) { OddsRatio = (PiTwo*(1.0-PiOne))/(PiOne*(1.0-PiTwo)) }</Rule>
            </Rules>
          </Parameter>
          <V0>0.1</V0>
          <V1 />
          <V2 />
          <V3 />
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="PiTwo" name="PiTwo" title="Group 2 Proportions, π₂​" type="Decimal" helpUri="Help/PTT/PTT12/PiTwo.html" readonly="false" format="F3">
            <Rules>
              <Rule name="Validate group 2 proportions, π₂" type="validation" message="The value entered for group 2 proportions, π₂, is outside the acceptable limits.">PiTwo &gt; 0 and PiTwo &lt; 1</Rule>
              <Rule name="Update Group 1 proportions" type="action">if((PiTwo != null) and (OddsRatio != null) and (PiOne == null)) { PiOne = PiTwo/(OddsRatio*(1.0-PiTwo) + PiTwo) }</Rule>
              <Rule name="Update odds ratio" type="action">if((PiOne != null) and (PiTwo != null)) { OddsRatio = (PiTwo*(1.0-PiOne))/(PiOne*(1.0-PiTwo)) }</Rule>
            </Rules>
          </Parameter>
          <V0>0.15</V0>
          <V1>0.25</V1>
          <V2>0.35</V2>
          <V3>0.59</V3>
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="OddsRatio" name="OddsRatio" title="Odds Ratio, Ψ=π₂(1-π₁)/π₁(1-π₂)​" type="Decimal" helpUri="Help/PTT/PTT12/OddsRatio.html" readonly="false" format="F10">
            <Rules>
              <Rule name="Validate odds ratio, Ψ" type="validation" message="The value entered for odds ratio, Ψ, is outside the acceptable limits.">OddsRatio &gt; 0 and (OddsRatio &gt; 1 or OddsRatio &lt; 1)</Rule>
              <Rule name="Update Group 1 proportions" type="action">if ((PiTwo != null) and (OddsRatio != null)) { PiOne = PiTwo/(OddsRatio*(1.0-PiTwo) + PiTwo) }</Rule>
              <Rule name="Update Group 2 proportions" type="action">if ((PiOne != null) and (OddsRatio != null)) { PiTwo = (OddsRatio*PiOne)/((1.0-PiOne)+(OddsRatio*PiOne)) }</Rule>
            </Rules>
          </Parameter>
          <V0 />
          <V1 />
          <V2 />
          <V3 />
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="N1" name="N1" title="Group 1 size, n₁​" type="Integer" helpUri="Help/PTT/PTT12/N1.html" readonly="false">
            <Rules>
              <Rule name="Validate sample size 1" type="validation" message="The value entered for sample size in group 1 is outside the acceptable limits.">N1 &gt;= 2</Rule>
              <Rule name="Update N2" type="action">if ((N1 != null) and (SampleSizeRatio != null)) { N2 = (N1 * SampleSizeRatio) }</Rule>
              <Rule name="Update SampleSizeRatio" type="action">if ((N1 != null) and (N2 != null) and (SampleSizeRatio == null) and (N1 != 0)) { SampleSizeRatio = ((double)N2) / ((double)N1) }</Rule>
              <Rule name="Update Total Study Cost" type="action">if ((N1 != null) and (N1 &gt; 0) and (N2 != null) and (N2 &gt; 0) and (CostPerSample != null) and (CostPerSample &gt; 0)) { TotalStudyCost = (N1 + N2) * CostPerSample }</Rule>
            </Rules>
          </Parameter>
          <V0 />
          <V1 />
          <V2 />
          <V3 />
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="N2" name="N2" title="Group 2 size, n₂​" type="Integer" helpUri="Help/PTT/PTT12/N2.html" readonly="false">
            <Rules>
              <Rule name="Validate sample size 2" type="validation" message="The value entered for sample size in group 2 is outside the acceptable limits.">N2 &gt;= 2</Rule>
              <Rule name="Update N1" type="action">if ((N2 != null) and (SampleSizeRatio != null) and (SampleSizeRatio != 0)) { N1 = (N2 / SampleSizeRatio) }</Rule>
              <Rule name="Update SampleSizeRatio" type="action">if ((N1 != null) and (N2 != null) and (SampleSizeRatio == null) and (N1 != 0)) { SampleSizeRatio = ((double)N2) / ((double)N1) }</Rule>
              <Rule name="Update Total Study Cost" type="action">if ((N1 != null) and (N1 &gt; 0) and (N2 != null) and (N2 &gt; 0) and (CostPerSample != null) and (CostPerSample &gt; 0)) { TotalStudyCost = (N1 + N2) * CostPerSample }</Rule>
            </Rules>
          </Parameter>
          <V0 />
          <V1 />
          <V2 />
          <V3 />
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="SampleSizeRatio" name="SampleSizeRatio" title="Ratio : n₂/n₁​" type="Decimal" defaultValue="1" helpUri="Help/PTT/PTT12/SampleSizeRatio.html" readonly="false" format="F3">
            <Rules>
              <Rule name="Validate ratio" type="validation" message="The ratio is outside the acceptable limits.">SampleSizeRatio &gt; 0</Rule>
              <Rule name="Update N2" type="action">if ((N1 != null) and (SampleSizeRatio != null)) { N2 = (N1 * SampleSizeRatio) }</Rule>
              <Rule name="Update N1" type="action">if ((N2 != null) and (N1 == null) and (SampleSizeRatio != null) and (SampleSizeRatio != 0)) { N1 = (N2 / SampleSizeRatio) }</Rule>
            </Rules>
          </Parameter>
          <V0>1</V0>
          <V1>1</V1>
          <V2>1</V2>
          <V3>1</V3>
          <V4>1</V4>
          <V5>1</V5>
          <V6>1</V6>
          <V7>1</V7>
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="ContinuityCorrection" name="ContinuityCorrection" title="Continuity correction​" type="OnOff" defaultValue="2" helpUri="Help/PTT/PTT12/ContinuityCorrection.html" readonly="false">
            <Rules>
              <Rule name="Validate information times" type="validation" message="The continuity correction value is either on or off">ContinuityCorrection == 1 or ContinuityCorrection == 2</Rule>
            </Rules>
          </Parameter>
          <V0>Off</V0>
          <V1>Off</V1>
          <V2>Off</V2>
          <V3>Off</V3>
          <V4>Off</V4>
          <V5>Off</V5>
          <V6>Off</V6>
          <V7>Off</V7>
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="VarianceTestType" name="VarianceTestType" title="Variance​" type="VarianceTestType" defaultValue="2" helpUri="Help/PTT/PTT12/VarianceTestType.html" readonly="false">
            <Rules>
              <Rule name="Validate test type" type="validation" message="The variance type is either Pooled or Unpooled">VarianceTestType == 1 or VarianceTestType == 2</Rule>
            </Rules>
          </Parameter>
          <V0>Pooled</V0>
          <V1>Pooled</V1>
          <V2>Pooled</V2>
          <V3>Pooled</V3>
          <V4>Pooled</V4>
          <V5>Pooled</V5>
          <V6>Pooled</V6>
          <V7>Pooled</V7>
        </MultipleFactorRow>
        <MultipleFactorRow>
          <Parameter id="Power" name="Power" title="Power (%)​" type="Decimal" helpUri="Help/PTT/PTT12/Power.html" readonly="false" format="P">
            <Rules>
              <Rule name="Validate power" type="validation" message="The value entered for power is outside the acceptable limits.">Power &gt; Alpha*100 and Power &lt; 100</Rule>
            </Rules>
          </Parameter>
          <V0>51</V0>
          <V1>80</V1>
          <V2>90</V2>
          <V3>99</V3>
          <V4 />
          <V5 />
          <V6 />
          <V7 />
        </MultipleFactorRow>
      </MultipleFactors>
