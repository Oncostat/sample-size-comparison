            <Parameter id="N2" name="N2" title="Group 2 size, n₂​" type="Integer" helpUri="Help/PTT/PTT12/N2.html" readonly="false">
              <Rules>
                <Rule name="Validate sample size 2" type="validation" message="The value entered for sample size in group 2 is outside the acceptable limits.">N2 &gt;= 2</Rule>
                <Rule name="Update N1" type="action">if ((N2 != null) and (SampleSizeRatio != null) and (SampleSizeRatio != 0)) { N1 = (N2 / SampleSizeRatio) }</Rule>
                <Rule name="Update SampleSizeRatio" type="action">if ((N1 != null) and (N2 != null) and (SampleSizeRatio == null) and (N1 != 0)) { SampleSizeRatio = ((double)N2) / ((double)N1) }</Rule>
                <Rule name="Update Total Study Cost" type="action">if ((N1 != null) and (N1 &gt; 0) and (N2 != null) and (N2 &gt; 0) and (CostPerSample != null) and (CostPerSample &gt; 0)) { TotalStudyCost = (N1 + N2) * CostPerSample }</Rule>
              </Rules>
            </Parameter>
