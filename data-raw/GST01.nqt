            <Parameter id="PiTwo" name="PiTwo" title="Group 2 Proportions, π₂​" type="Decimal" helpUri="Help/PTT/PTT12/PiTwo.html" readonly="false" format="F3">
              <Rules>
                <Rule name="Validate group 2 proportions, π₂" type="validation" message="The value entered for group 2 proportions, π₂, is outside the acceptable limits.">PiTwo &gt; 0 and PiTwo &lt; 1</Rule>
                <Rule name="Update Group 1 proportions" type="action">if((PiTwo != null) and (OddsRatio != null) and (PiOne == null)) { PiOne = PiTwo/(OddsRatio*(1.0-PiTwo) + PiTwo) }</Rule>
                <Rule name="Update odds ratio" type="action">if((PiOne != null) and (PiTwo != null)) { OddsRatio = (PiTwo*(1.0-PiOne))/(PiOne*(1.0-PiTwo)) }</Rule>
              </Rules>
            </Parameter>
